{% if include.calendar_id %}
  <div class="post mt-4">
    <h2 class="mb-3"><i class="fas fa-calendar-alt"></i> Upcoming Events</h2>

    <button
      class="btn btn-sm btn-outline-primary mb-3"
      onclick="toggleCalendar()"
      id="calendar-toggle-btn"
    >
      Show Calendar
    </button>

    <div class="calendar-wrapper calendar-wrapper-hidden" id="calendar-container">
      <iframe
        id="calendar-iframe"
        data-calendar-id="{{ include.calendar_id }}"
        data-timezone="{{ include.timezone | default: 'UTC' }}"
        class="calendar-iframe{% if include.style %} calendar-iframe-custom{% endif %}"
        {% if include.style %}
          style="{{ include.style }}"
        {% endif %}
        frameborder="0"
        scrolling="no"
      >
      </iframe>
    </div>
  </div>
{% endif %}
