  title  = "{Vaiyyākaraṇaḥ}: A Sanskrit Grammar Bot for Telegram",
  author = "Terdalkar, Hrishikesh and Akavarapu, V S D S Mahesh and Agarwal, Shubhangi and Bhattacharya, Arnab",
